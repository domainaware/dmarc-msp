# Copy to .env and fill in real values.
# This file is used by Docker Compose for variable substitution.

# The MSP's DMARC receiving domain (used by Postfix, nginx, and certbot)
MSP_DOMAIN=dmarc.msp-example.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@msp-example.com

# OpenSearch (used by OpenSearch, Dashboards, and dmarc-msp containers.
# The same password must also be set in parsedmarc.ini.)
OPENSEARCH_ADMIN_PASSWORD=changeme

# Set an IPinfo API token if you prefer to use their API for IP lookups
# IPINFO_API_TOKEN=

# Bind addresses (optional, default 0.0.0.0 = all interfaces)
# Separate IPs let you put HTTP behind Cloudflare while SMTP uses an IP
# with matching forward/reverse DNS for deliverability.
# HTTP_BIND_IP=203.0.113.1
# SMTP_BIND_IP=203.0.113.2

# DNS provider (uncomment the one you use)
# CLOUDFLARE_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
