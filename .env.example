# Copy to .env and fill in real values.
# This file is used by Docker Compose for variable substitution.

# The MSP's DMARC receiving domain (used by Postfix and certbot)
MSP_DOMAIN=dmarc.msp-example.com

# OpenSearch (used by OpenSearch, Dashboards, and dmarc-msp containers.
# The same password must also be set in parsedmarc.ini.)
OPENSEARCH_ADMIN_PASSWORD=changeme

# DNS provider (uncomment the one you use)
# CLOUDFLARE_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
